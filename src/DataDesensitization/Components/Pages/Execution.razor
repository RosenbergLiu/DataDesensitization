@page "/execute"
@inject IDesensitizationEngine DesensitizationEngine
@inject IRuleConfigurationService RuleConfigurationService
@inject IReportSerializer ReportSerializer
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Execute Desensitization</PageTitle>

<div class="max-w-5xl">
    <h2 class="text-2xl font-bold text-gray-900">Execute Desensitization</h2>
    <p class="mt-1 text-sm text-gray-500">Run desensitization rules against your live database.</p>

    @if (errorMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
            <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-red-700">@errorMessage</p>
        </div>
    }

    @if (!isRunning && report is null)
    {
        <div class="mt-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-gray-500">Configured rules: <span class="font-semibold text-gray-900">@RuleConfigurationService.Rules.Count</span></p>
                    @if (RuleConfigurationService.Rules.Count == 0)
                    {
                        <p class="mt-1 text-xs text-amber-600">At least one desensitization rule must be configured before execution.</p>
                    }
                </div>
                <button class="inline-flex items-center gap-2 rounded-lg bg-emerald-600 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500/50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                        @onclick="StartExecutionAsync"
                        disabled="@(RuleConfigurationService.Rules.Count == 0)">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/></svg>
                    Start Desensitization
                </button>
            </div>
        </div>
    }

    @if (isRunning)
    {
        <div class="mt-6 rounded-xl border border-brand-200 bg-white p-6 shadow-sm">
            <h3 class="text-lg font-semibold text-gray-900">Desensitization in Progress</h3>

            <div class="mt-4 space-y-3">
                <p class="text-sm text-gray-600">Current Table: <span class="font-medium text-gray-900">@(currentProgress?.CurrentTable ?? "Initializing...")</span></p>

                <div class="w-full bg-gray-200 rounded-full h-3 overflow-hidden" role="progressbar" aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">
                    <div class="bg-brand-600 h-3 rounded-full transition-all duration-300 ease-out" style="width: @(progressPercent)%"></div>
                </div>

                <div class="flex items-center justify-between text-xs text-gray-500">
                    <span>Rows: @(currentProgress?.RowsProcessed ?? 0) / @(currentProgress?.TotalRows ?? 0)</span>
                    <span>@(progressPercent)%</span>
                    <span>Est. remaining: @FormatTimeRemaining(currentProgress?.EstimatedTimeRemaining)</span>
                </div>

                <button class="mt-2 inline-flex items-center gap-2 rounded-lg border border-red-300 bg-white px-4 py-2 text-sm font-semibold text-red-600 shadow-sm hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-red-500/50 transition-colors"
                        @onclick="CancelExecution">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    Cancel
                </button>
            </div>
        </div>
    }

    @if (report is not null)
    {
        <div class="mt-6 rounded-xl border border-emerald-200 bg-white shadow-sm overflow-hidden">
            <div class="bg-emerald-600 px-6 py-4">
                <h3 class="text-lg font-semibold text-white">Execution Report</h3>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Started</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Completed</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.CompletedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Total Elapsed</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.TotalElapsed.ToString(@"hh\:mm\:ss\.fff")</p>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Rows Updated</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.TotalRowsUpdated</p>
                    </div>
                </div>

                @if (report.TotalErrors > 0)
                {
                    <div class="mb-4 flex items-start gap-3 rounded-lg bg-amber-50 border border-amber-200 p-4">
                        <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                        <p class="text-sm text-amber-700">@report.TotalErrors table(s) encountered errors during execution.</p>
                    </div>
                }

                <div class="rounded-xl border border-gray-200 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-gray-50 text-left">
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Table Name</th>
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Rows Updated</th>
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Elapsed</th>
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @foreach (var result in report.TableResults)
                                {
                                    <tr class="@(result.Error is not null ? "bg-red-50/50" : "hover:bg-gray-50") transition-colors">
                                        <td class="px-5 py-3 font-medium text-gray-900">@result.TableName</td>
                                        <td class="px-5 py-3 text-gray-700">@result.RowsUpdated</td>
                                        <td class="px-5 py-3 text-gray-500 font-mono text-xs">@result.Elapsed.ToString(@"hh\:mm\:ss\.fff")</td>
                                        <td class="px-5 py-3">
                                            @if (result.Error is not null)
                                            {
                                                <span class="text-red-600 text-xs">@result.Error</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Success</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="mt-4">
                    <button class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500/50 transition-colors"
                            @onclick="Reset">
                        Run Again
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool isRunning;
    private string? errorMessage;
    private ProgressInfo? currentProgress;
    private ExecutionReport? report;
    private CancellationTokenSource? cts;
    private int progressPercent;

    protected override void OnInitialized()
    {
        DesensitizationEngine.ProgressChanged += OnProgressChanged;
    }

    private async Task StartExecutionAsync()
    {
        errorMessage = null;
        report = null;
        isRunning = true;
        currentProgress = null;
        progressPercent = 0;
        cts = new CancellationTokenSource();

        try
        {
            report = await DesensitizationEngine.ExecuteAsync(
                RuleConfigurationService.Rules, cts.Token);

            if (report is not null)
            {
                await DownloadReportAsync(report);
            }
        }
        catch (OperationCanceledException)
        {
            errorMessage = "Desensitization was cancelled. Any uncommitted changes have been rolled back.";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Execution failed: {ex.Message}";
        }
        finally
        {
            isRunning = false;
            cts?.Dispose();
            cts = null;
        }
    }

    private void CancelExecution()
    {
        cts?.Cancel();
    }

    private async Task DownloadReportAsync(ExecutionReport executionReport)
    {
        var json = ReportSerializer.Serialize(executionReport);
        var fileName = $"desensitization-report-{executionReport.StartedAt:yyyyMMdd-HHmmss}.json";
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);

        await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, bytes);
    }

    private void OnProgressChanged(ProgressInfo progress)
    {
        InvokeAsync(() =>
        {
            currentProgress = progress;
            progressPercent = progress.TotalRows > 0
                ? (int)(progress.RowsProcessed * 100 / progress.TotalRows)
                : 0;
            StateHasChanged();
        });
    }

    private void Reset()
    {
        report = null;
        errorMessage = null;
        currentProgress = null;
        progressPercent = 0;
    }

    private static string FormatTimeRemaining(TimeSpan? remaining)
    {
        if (remaining is null)
            return "Calculating...";
        if (remaining.Value.TotalSeconds < 1)
            return "< 1s";
        return remaining.Value.ToString(@"hh\:mm\:ss");
    }

    public void Dispose()
    {
        DesensitizationEngine.ProgressChanged -= OnProgressChanged;
        cts?.Dispose();
    }
}
