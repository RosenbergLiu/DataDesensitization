@page "/execute"
@rendermode InteractiveServer
@inject IDesensitizationEngine DesensitizationEngine
@inject IRuleConfigurationService RuleConfigurationService
@implements IDisposable

<PageTitle>Execute Desensitization</PageTitle>

<h3>Execute Desensitization</h3>

@if (errorMessage is not null)
{
    <div class="alert alert-danger mt-2" role="alert">@errorMessage</div>
}

@if (!isRunning && report is null)
{
    <div class="mt-3">
        <p class="text-muted">
            Configured rules: <strong>@RuleConfigurationService.Rules.Count</strong>
        </p>
        <button class="btn btn-success btn-lg"
                @onclick="StartExecutionAsync"
                disabled="@(RuleConfigurationService.Rules.Count == 0)">
            <span class="bi bi-play-fill me-1" aria-hidden="true"></span> Start Desensitization
        </button>
        @if (RuleConfigurationService.Rules.Count == 0)
        {
            <div class="form-text text-warning mt-2">
                At least one desensitization rule must be configured before execution.
            </div>
        }
    </div>
}

@if (isRunning)
{
    <div class="card mt-3">
        <div class="card-body">
            <h5 class="card-title">Desensitization in Progress</h5>

            <div class="mb-3">
                <strong>Current Table:</strong> @(currentProgress?.CurrentTable ?? "Initializing...")
            </div>

            <div class="progress mb-2" role="progressbar"
                 aria-valuenow="@progressPercent" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar progress-bar-striped progress-bar-animated"
                     style="width: @(progressPercent)%">
                    @(progressPercent)%
                </div>
            </div>

            <div class="row text-muted mb-3">
                <div class="col-auto">
                    <small>Rows: @(currentProgress?.RowsProcessed ?? 0) / @(currentProgress?.TotalRows ?? 0)</small>
                </div>
                <div class="col-auto">
                    <small>Est. remaining: @FormatTimeRemaining(currentProgress?.EstimatedTimeRemaining)</small>
                </div>
            </div>

            <button class="btn btn-danger" @onclick="CancelExecution">
                <span class="bi bi-x-circle me-1" aria-hidden="true"></span> Cancel
            </button>
        </div>
    </div>
}

@if (report is not null)
{
    <div class="card mt-3">
        <div class="card-header bg-success text-white">
            <h5 class="mb-0">Execution Report</h5>
        </div>
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-3">
                    <strong>Started:</strong><br />@report.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")
                </div>
                <div class="col-md-3">
                    <strong>Completed:</strong><br />@report.CompletedAt.ToString("yyyy-MM-dd HH:mm:ss")
                </div>
                <div class="col-md-3">
                    <strong>Total Elapsed:</strong><br />@report.TotalElapsed.ToString(@"hh\:mm\:ss\.fff")
                </div>
                <div class="col-md-3">
                    <strong>Total Rows Updated:</strong><br />@report.TotalRowsUpdated
                </div>
            </div>

            @if (report.TotalErrors > 0)
            {
                <div class="alert alert-warning">
                    @report.TotalErrors table(s) encountered errors during execution.
                </div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-sm">
                    <thead class="table-light">
                        <tr>
                            <th>Table Name</th>
                            <th>Rows Updated</th>
                            <th>Elapsed</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var result in report.TableResults)
                        {
                            <tr class="@(result.Error is not null ? "table-danger" : "")">
                                <td>@result.TableName</td>
                                <td>@result.RowsUpdated</td>
                                <td>@result.Elapsed.ToString(@"hh\:mm\:ss\.fff")</td>
                                <td>
                                    @if (result.Error is not null)
                                    {
                                        <span class="text-danger">@result.Error</span>
                                    }
                                    else
                                    {
                                        <span class="text-success">Success</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <button class="btn btn-primary mt-2" @onclick="Reset">
                Run Again
            </button>
        </div>
    </div>
}

@code {
    private bool isRunning;
    private string? errorMessage;
    private ProgressInfo? currentProgress;
    private ExecutionReport? report;
    private CancellationTokenSource? cts;
    private int progressPercent;

    protected override void OnInitialized()
    {
        DesensitizationEngine.ProgressChanged += OnProgressChanged;
    }

    private async Task StartExecutionAsync()
    {
        errorMessage = null;
        report = null;
        isRunning = true;
        currentProgress = null;
        progressPercent = 0;
        cts = new CancellationTokenSource();

        try
        {
            report = await DesensitizationEngine.ExecuteAsync(
                RuleConfigurationService.Rules, cts.Token);
        }
        catch (OperationCanceledException)
        {
            errorMessage = "Desensitization was cancelled. Any uncommitted changes have been rolled back.";
        }
        catch (InvalidOperationException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = $"Execution failed: {ex.Message}";
        }
        finally
        {
            isRunning = false;
            cts?.Dispose();
            cts = null;
        }
    }

    private void CancelExecution()
    {
        cts?.Cancel();
    }

    private void OnProgressChanged(ProgressInfo progress)
    {
        InvokeAsync(() =>
        {
            currentProgress = progress;
            progressPercent = progress.TotalRows > 0
                ? (int)(progress.RowsProcessed * 100 / progress.TotalRows)
                : 0;
            StateHasChanged();
        });
    }

    private void Reset()
    {
        report = null;
        errorMessage = null;
        currentProgress = null;
        progressPercent = 0;
    }

    private static string FormatTimeRemaining(TimeSpan? remaining)
    {
        if (remaining is null)
            return "Calculating...";
        if (remaining.Value.TotalSeconds < 1)
            return "< 1s";
        return remaining.Value.ToString(@"hh\:mm\:ss");
    }

    public void Dispose()
    {
        DesensitizationEngine.ProgressChanged -= OnProgressChanged;
        cts?.Dispose();
    }
}
