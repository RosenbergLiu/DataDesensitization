@page "/rules"
@inject IRuleConfigurationService RuleConfigurationService
@inject ISchemaService SchemaService

<PageTitle>Rule Configuration</PageTitle>

<div class="max-w-5xl">
    <h2 class="text-xl sm:text-2xl font-bold text-gray-900">Rule Configuration</h2>
    <p class="mt-1 text-sm text-gray-500">Define desensitization strategies for your database columns.</p>

    @if (validationError is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
            <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-red-700">@validationError</p>
        </div>
    }

    @if (successMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-emerald-50 border border-emerald-200 p-4" role="alert">
            <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-emerald-700">@successMessage</p>
        </div>
    }

    <!-- Current Rules -->
    <div class="mt-4 sm:mt-6">
        <h3 class="text-lg font-semibold text-gray-900">Current Rules</h3>
        @if (RuleConfigurationService.Rules.Count == 0)
        {
            <div class="mt-3 text-center py-8 rounded-xl border border-dashed border-gray-300 bg-white">
                <p class="text-sm text-gray-500">No rules configured yet.</p>
            </div>
        }
        else
        {
            <!-- Desktop table -->
            <div class="mt-3 rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden hidden sm:block">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 text-left">
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Table</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Column</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Strategy</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Parameters</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var rule in RuleConfigurationService.Rules)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-5 py-3 font-medium text-gray-900">@rule.TableName</td>
                                    <td class="px-5 py-3 text-gray-700">@rule.ColumnName</td>
                                    <td class="px-5 py-3">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-100 text-brand-700">@rule.Strategy</span>
                                    </td>
                                    <td class="px-5 py-3 text-gray-500 text-xs">@FormatParameters(rule)</td>
                                    <td class="px-5 py-3">
                                        <button class="text-red-600 hover:text-red-800 text-xs font-medium transition-colors" @onclick="() => RemoveRule(rule)">Remove</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Mobile cards -->
            <div class="mt-3 space-y-3 sm:hidden">
                @foreach (var rule in RuleConfigurationService.Rules)
                {
                    <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
                        <div class="flex items-start justify-between">
                            <div class="min-w-0">
                                <p class="font-medium text-gray-900 text-sm truncate">@rule.TableName</p>
                                <p class="text-gray-600 text-sm">@rule.ColumnName</p>
                            </div>
                            <button class="text-red-600 hover:text-red-800 text-xs font-medium ml-2 shrink-0" @onclick="() => RemoveRule(rule)">Remove</button>
                        </div>
                        <div class="mt-2 flex flex-wrap items-center gap-2">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-100 text-brand-700">@rule.Strategy</span>
                            <span class="text-gray-500 text-xs">@FormatParameters(rule)</span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Add New Rule -->
    <div class="mt-6 sm:mt-8 rounded-xl border border-gray-200 bg-white p-4 sm:p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Add New Rule</h3>
        <div class="mt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
            <div class="relative" @onfocusout="() => HideTableSuggestionsDelayed()">
                <label for="tableName" class="block text-sm font-medium text-gray-700 mb-1.5">Table Name</label>
                <input id="tableName" type="text" autocomplete="off"
                       class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors"
                       value="@newTableName"
                       @oninput="OnTableNameInput"
                       @onfocus="OnTableNameFocus"
                       placeholder="e.g. dbo.Users"
                       role="combobox"
                       aria-expanded="@(showTableSuggestions && tableSuggestions.Count > 0)"
                       aria-autocomplete="list"
                       aria-controls="tableSuggestionsList" />
                @if (showTableSuggestions && tableSuggestions.Count > 0)
                {
                    <ul id="tableSuggestionsList" role="listbox"
                        class="absolute z-10 mt-1 w-full max-h-48 overflow-auto rounded-lg border border-gray-200 bg-white shadow-lg">
                        @foreach (var table in tableSuggestions)
                        {
                            var fullName = $"{table.SchemaName}.{table.TableName}";
                            <li role="option" class="px-3.5 py-2 text-sm text-gray-900 cursor-pointer hover:bg-brand-50 hover:text-brand-700 transition-colors"
                                @onmousedown="() => SelectTable(fullName)"
                                @onmousedown:preventDefault>
                                @fullName
                            </li>
                        }
                    </ul>
                }
            </div>
            <div class="relative" @onfocusout="() => HideColumnSuggestionsDelayed()">
                <label for="columnName" class="block text-sm font-medium text-gray-700 mb-1.5">Column Name</label>
                <input id="columnName" type="text" autocomplete="off"
                       class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors"
                       value="@newColumnName"
                       @oninput="OnColumnNameInput"
                       @onfocus="OnColumnNameFocus"
                       placeholder="e.g. Email"
                       role="combobox"
                       aria-expanded="@(showColumnSuggestions && columnSuggestions.Count > 0)"
                       aria-autocomplete="list"
                       aria-controls="columnSuggestionsList" />
                @if (showColumnSuggestions && columnSuggestions.Count > 0)
                {
                    <ul id="columnSuggestionsList" role="listbox"
                        class="absolute z-10 mt-1 w-full max-h-48 overflow-auto rounded-lg border border-gray-200 bg-white shadow-lg">
                        @foreach (var col in columnSuggestions)
                        {
                            var isFk = col.IsForeignKey;
                            <li role="option" class="@(isFk ? "px-3.5 py-2 text-sm text-gray-400 cursor-not-allowed bg-gray-50" : "px-3.5 py-2 text-sm text-gray-900 cursor-pointer hover:bg-brand-50 hover:text-brand-700 transition-colors")"
                                @onmousedown="() => { if (!isFk) SelectColumn(col.ColumnName); }"
                                @onmousedown:preventDefault
                                aria-disabled="@isFk">
                                <span>@col.ColumnName</span>
                                <span class="ml-2 text-xs text-gray-400">@col.DataType</span>
                                @if (isFk)
                                {
                                    <span class="ml-2 inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-amber-100 text-amber-700" title="Foreign key — references @col.ReferencedTable">FK</span>
                                }
                            </li>
                        }
                    </ul>
                }
            </div>
            <div>
                <label for="strategy" class="block text-sm font-medium text-gray-700 mb-1.5">Strategy</label>
                <select id="strategy"
                        class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors bg-white"
                        @bind="selectedStrategy">
                    @foreach (var s in Enum.GetValues<DesensitizationStrategyType>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
        </div>

        <!-- Strategy-specific parameters -->
        @if (selectedStrategy == DesensitizationStrategyType.Randomization)
        {
            <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 rounded-lg bg-gray-50 border border-gray-200">
                <div>
                    <label for="minLength" class="block text-sm font-medium text-gray-700 mb-1.5">Min Length</label>
                    <input id="minLength" type="number" class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors" @bind="paramMinLength" min="0" />
                </div>
                <div>
                    <label for="maxLength" class="block text-sm font-medium text-gray-700 mb-1.5">Max Length</label>
                    <input id="maxLength" type="number" class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors" @bind="paramMaxLength" min="0" />
                </div>
            </div>
        }

        @if (selectedStrategy == DesensitizationStrategyType.Masking)
        {
            <div class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-4 p-4 rounded-lg bg-gray-50 border border-gray-200">
                <div>
                    <label for="maskChar" class="block text-sm font-medium text-gray-700 mb-1.5">Mask Character</label>
                    <input id="maskChar" type="text" class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors" @bind="paramMaskChar" maxlength="1" />
                </div>
                <div>
                    <label for="preserveStart" class="block text-sm font-medium text-gray-700 mb-1.5">Preserve Start</label>
                    <input id="preserveStart" type="number" class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors" @bind="paramPreserveStart" min="0" />
                </div>
                <div>
                    <label for="preserveEnd" class="block text-sm font-medium text-gray-700 mb-1.5">Preserve End</label>
                    <input id="preserveEnd" type="number" class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors" @bind="paramPreserveEnd" min="0" />
                </div>
            </div>
        }

        @if (selectedStrategy == DesensitizationStrategyType.FixedValue)
        {
            <div class="mt-4 p-4 rounded-lg bg-gray-50 border border-gray-200">
                <label for="fixedValue" class="block text-sm font-medium text-gray-700 mb-1.5">Fixed Value</label>
                <input id="fixedValue" type="text" class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors" @bind="paramFixedValue" placeholder="Replacement value" />
            </div>
        }

        <div class="mt-5">
            <button class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500/50 transition-colors" @onclick="AddRule">
                Add Rule
            </button>
        </div>
    </div>

    <!-- Auto-Detection -->
    <div class="mt-6 sm:mt-8 rounded-xl border border-gray-200 bg-white p-4 sm:p-6 shadow-sm">
        <h3 class="text-lg font-semibold text-gray-900">Auto-Detection</h3>
        <p class="mt-1 text-sm text-gray-500">Automatically detect columns that may contain sensitive data.</p>
        <div class="mt-4">
            <button class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-brand-500/50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                    @onclick="AutoDetectAsync" disabled="@isDetecting">
                @if (isDetecting)
                {
                    <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                    <span>Detecting...</span>
                }
                else
                {
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
                    <span>Auto-Detect Sensitive Columns</span>
                }
            </button>
        </div>

        @if (suggestions.Count > 0)
        {
            <!-- Desktop table -->
            <div class="mt-4 rounded-xl border border-gray-200 overflow-hidden hidden sm:block">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 text-left">
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Table</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Column</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Suggested Strategy</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var suggestion in suggestions)
                            {
                                <tr class="hover:bg-gray-50 transition-colors">
                                    <td class="px-5 py-3 font-medium text-gray-900">@suggestion.TableName</td>
                                    <td class="px-5 py-3 text-gray-700">@suggestion.ColumnName</td>
                                    <td class="px-5 py-3">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700">@suggestion.Strategy</span>
                                    </td>
                                    <td class="px-5 py-3 flex items-center gap-2">
                                        <button class="inline-flex items-center px-3 py-1.5 rounded-md bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700 transition-colors" @onclick="() => AcceptSuggestion(suggestion)">Accept</button>
                                        <button class="inline-flex items-center px-3 py-1.5 rounded-md border border-gray-300 text-gray-600 text-xs font-medium hover:bg-gray-50 transition-colors" @onclick="() => DismissSuggestion(suggestion)">Dismiss</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <!-- Mobile cards -->
            <div class="mt-4 space-y-3 sm:hidden">
                @foreach (var suggestion in suggestions)
                {
                    <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
                        <p class="font-medium text-gray-900 text-sm truncate">@suggestion.TableName</p>
                        <p class="text-gray-600 text-sm">@suggestion.ColumnName</p>
                        <div class="mt-2 flex items-center justify-between">
                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-sky-100 text-sky-700">@suggestion.Strategy</span>
                            <div class="flex items-center gap-2">
                                <button class="inline-flex items-center px-3 py-1.5 rounded-md bg-emerald-600 text-white text-xs font-medium hover:bg-emerald-700 transition-colors" @onclick="() => AcceptSuggestion(suggestion)">Accept</button>
                                <button class="inline-flex items-center px-3 py-1.5 rounded-md border border-gray-300 text-gray-600 text-xs font-medium hover:bg-gray-50 transition-colors" @onclick="() => DismissSuggestion(suggestion)">Dismiss</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string newTableName = string.Empty;
    private string newColumnName = string.Empty;
    private DesensitizationStrategyType selectedStrategy = DesensitizationStrategyType.Randomization;
    private int? paramMinLength;
    private int? paramMaxLength;
    private string paramMaskChar = "*";
    private int paramPreserveStart;
    private int paramPreserveEnd;
    private string paramFixedValue = string.Empty;
    private string? validationError;
    private string? successMessage;
    private bool isDetecting;
    private List<DesensitizationRule> suggestions = new();

    private List<TableInfo> tableSuggestions = new();
    private List<ColumnInfo> columnSuggestions = new();
    private List<ColumnInfo> allColumnsForTable = new();
    private bool showTableSuggestions;
    private bool showColumnSuggestions;
    private CancellationTokenSource? tableSearchCts;

    private async Task OnTableNameInput(ChangeEventArgs e)
    {
        newTableName = e.Value?.ToString() ?? string.Empty;
        newColumnName = string.Empty;
        allColumnsForTable.Clear();
        columnSuggestions.Clear();

        tableSearchCts?.Cancel();
        tableSearchCts = new CancellationTokenSource();

        try
        {
            tableSuggestions = await SchemaService.SearchTablesAsync(newTableName, tableSearchCts.Token);
            showTableSuggestions = true;
        }
        catch (OperationCanceledException) { }
    }

    private async Task OnTableNameFocus()
    {
        if (tableSuggestions.Count == 0)
        {
            try
            {
                tableSuggestions = await SchemaService.SearchTablesAsync(newTableName);
                showTableSuggestions = true;
            }
            catch { }
        }
        else
        {
            showTableSuggestions = true;
        }
    }

    private void SelectTable(string fullName)
    {
        newTableName = fullName;
        showTableSuggestions = false;
        newColumnName = string.Empty;
        allColumnsForTable.Clear();
        columnSuggestions.Clear();
        _ = LoadColumnsForTable(fullName);
    }

    private async Task LoadColumnsForTable(string tableName)
    {
        try
        {
            allColumnsForTable = await SchemaService.GetColumnsAsync(tableName);
        }
        catch { allColumnsForTable.Clear(); }
    }

    private async Task OnColumnNameInput(ChangeEventArgs e)
    {
        newColumnName = e.Value?.ToString() ?? string.Empty;

        if (allColumnsForTable.Count == 0 && !string.IsNullOrWhiteSpace(newTableName))
        {
            await LoadColumnsForTable(newTableName);
        }

        var filter = newColumnName;
        columnSuggestions = string.IsNullOrWhiteSpace(filter)
            ? allColumnsForTable.ToList()
            : allColumnsForTable
                .Where(c => c.ColumnName.Contains(filter, StringComparison.OrdinalIgnoreCase))
                .ToList();
        showColumnSuggestions = true;
    }

    private async Task OnColumnNameFocus()
    {
        if (allColumnsForTable.Count == 0 && !string.IsNullOrWhiteSpace(newTableName))
        {
            await LoadColumnsForTable(newTableName);
        }

        columnSuggestions = string.IsNullOrWhiteSpace(newColumnName)
            ? allColumnsForTable.ToList()
            : allColumnsForTable
                .Where(c => c.ColumnName.Contains(newColumnName, StringComparison.OrdinalIgnoreCase))
                .ToList();
        showColumnSuggestions = true;
    }

    private void SelectColumn(string columnName)
    {
        newColumnName = columnName;
        showColumnSuggestions = false;
    }

    private async void HideTableSuggestionsDelayed()
    {
        await Task.Delay(150);
        showTableSuggestions = false;
        await InvokeAsync(StateHasChanged);
    }

    private async void HideColumnSuggestionsDelayed()
    {
        await Task.Delay(150);
        showColumnSuggestions = false;
        await InvokeAsync(StateHasChanged);
    }

    private void AddRule()
    {
        validationError = null;
        successMessage = null;

        if (string.IsNullOrWhiteSpace(newTableName) || string.IsNullOrWhiteSpace(newColumnName))
        {
            validationError = "Table name and column name are required.";
            return;
        }

        var selectedColumn = allColumnsForTable
            .FirstOrDefault(c => string.Equals(c.ColumnName, newColumnName.Trim(), StringComparison.OrdinalIgnoreCase));

        if (selectedColumn is not null && selectedColumn.IsForeignKey)
        {
            var refInfo = selectedColumn.ReferencedTable is not null
                ? $" (references {selectedColumn.ReferencedTable})"
                : string.Empty;
            validationError = $"Cannot add a rule to '{newColumnName}' because it is a foreign key{refInfo}. Modifying foreign key values would break referential integrity.";
            return;
        }

        var parameters = BuildParameters();
        var rule = new DesensitizationRule(newTableName.Trim(), newColumnName.Trim(), selectedStrategy, parameters);

        if (selectedColumn is not null)
        {
            var validation = RuleConfigurationService.ValidateRule(rule, selectedColumn);
            if (!validation.IsValid)
            {
                validationError = validation.ErrorMessage;
                return;
            }
        }

        var result = RuleConfigurationService.AddRule(rule);

        if (!result.IsValid)
        {
            validationError = result.ErrorMessage;
        }
        else
        {
            successMessage = $"Rule added: {rule.Strategy} on {rule.TableName}.{rule.ColumnName}";
            ResetForm();
        }
    }

    private StrategyParameters BuildParameters()
    {
        return selectedStrategy switch
        {
            DesensitizationStrategyType.Randomization => new StrategyParameters
            {
                MinLength = paramMinLength,
                MaxLength = paramMaxLength
            },
            DesensitizationStrategyType.Masking => new StrategyParameters
            {
                MaskCharacter = string.IsNullOrEmpty(paramMaskChar) ? '*' : paramMaskChar[0],
                PreserveStart = paramPreserveStart,
                PreserveEnd = paramPreserveEnd
            },
            DesensitizationStrategyType.FixedValue => new StrategyParameters
            {
                FixedValue = paramFixedValue
            },
            _ => new StrategyParameters()
        };
    }

    private void ResetForm()
    {
        newTableName = string.Empty;
        newColumnName = string.Empty;
        selectedStrategy = DesensitizationStrategyType.Randomization;
        paramMinLength = null;
        paramMaxLength = null;
        paramMaskChar = "*";
        paramPreserveStart = 0;
        paramPreserveEnd = 0;
        paramFixedValue = string.Empty;
        tableSuggestions.Clear();
        columnSuggestions.Clear();
        allColumnsForTable.Clear();
        showTableSuggestions = false;
        showColumnSuggestions = false;
    }

    private void RemoveRule(DesensitizationRule rule)
    {
        RuleConfigurationService.RemoveRule(rule.TableName, rule.ColumnName);
        successMessage = $"Removed rule for {rule.TableName}.{rule.ColumnName}";
        validationError = null;
    }

    private async Task AutoDetectAsync()
    {
        isDetecting = true;
        validationError = null;
        successMessage = null;

        try
        {
            var tables = await SchemaService.GetTablesAsync();
            var columnsByTable = new Dictionary<string, List<ColumnInfo>>();

            foreach (var table in tables)
            {
                var key = $"{table.SchemaName}.{table.TableName}";
                var columns = await SchemaService.GetColumnsAsync(key);
                columnsByTable[key] = columns;
            }

            suggestions = RuleConfigurationService.AutoDetectRules(tables, columnsByTable);
            suggestions = suggestions
                .Where(s => !RuleConfigurationService.Rules.Any(r =>
                    string.Equals(r.TableName, s.TableName, StringComparison.OrdinalIgnoreCase) &&
                    string.Equals(r.ColumnName, s.ColumnName, StringComparison.OrdinalIgnoreCase)))
                .ToList();

            if (suggestions.Count == 0)
                successMessage = "No new sensitive columns detected.";
            else
                successMessage = $"Found {suggestions.Count} suggestion(s).";
        }
        catch (Exception ex)
        {
            validationError = $"Auto-detection failed: {ex.Message}";
        }
        finally
        {
            isDetecting = false;
        }
    }

    private void AcceptSuggestion(DesensitizationRule suggestion)
    {
        RuleConfigurationService.AddRule(suggestion);
        suggestions.Remove(suggestion);
        successMessage = $"Accepted: {suggestion.Strategy} on {suggestion.TableName}.{suggestion.ColumnName}";
        validationError = null;
    }

    private void DismissSuggestion(DesensitizationRule suggestion)
    {
        suggestions.Remove(suggestion);
    }

    private string FormatParameters(DesensitizationRule rule)
    {
        return rule.Strategy switch
        {
            DesensitizationStrategyType.Randomization =>
                $"MinLength={rule.Parameters.MinLength?.ToString() ?? "—"}, MaxLength={rule.Parameters.MaxLength?.ToString() ?? "—"}",
            DesensitizationStrategyType.Masking =>
                $"Mask='{rule.Parameters.MaskCharacter}', PreserveStart={rule.Parameters.PreserveStart}, PreserveEnd={rule.Parameters.PreserveEnd}",
            DesensitizationStrategyType.FixedValue =>
                $"Value=\"{rule.Parameters.FixedValue ?? ""}\"",
            _ => "—"
        };
    }
}
