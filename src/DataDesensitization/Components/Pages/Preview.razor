@page "/preview"
@inject IDesensitizationEngine DesensitizationEngine
@inject IRuleConfigurationService RuleConfigurationService
@inject ISchemaService SchemaService

<PageTitle>Data Preview</PageTitle>

<div class="max-w-5xl">
    <h2 class="text-xl sm:text-2xl font-bold text-gray-900">Data Preview</h2>
    <p class="mt-1 text-sm text-gray-500">Preview how your data will look after desensitization.</p>

    @if (errorMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
            <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-red-700">@errorMessage</p>
        </div>
    }

    @if (infoMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-sky-50 border border-sky-200 p-4" role="alert">
            <svg class="w-5 h-5 text-sky-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-sky-700">@infoMessage</p>
        </div>
    }

    <div class="mt-4 sm:mt-6 rounded-xl border border-gray-200 bg-white p-4 sm:p-6 shadow-sm">
        <div class="flex flex-col sm:flex-row gap-4 items-end">
            <div class="flex-1 relative">
                <label for="tableName" class="block text-sm font-medium text-gray-700 mb-1.5">Table Name</label>
                <input id="tableName" type="text" autocomplete="off"
                       class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors"
                       @bind="tableName" @bind:event="oninput" @bind:after="OnTableNameInputAsync"
                       @onfocus="() => showSuggestions = tableSuggestions.Count > 0"
                       @onblur="OnInputBlurAsync"
                       placeholder="e.g. dbo.Users"
                       role="combobox" aria-expanded="@showSuggestions" aria-autocomplete="list" aria-controls="table-suggestions" />
                @if (showSuggestions && tableSuggestions.Count > 0)
                {
                    <ul id="table-suggestions" role="listbox"
                        class="absolute z-10 mt-1 w-full max-h-48 overflow-auto rounded-lg border border-gray-200 bg-white shadow-lg">
                        @foreach (var suggestion in tableSuggestions)
                        {
                            var displayName = $"{suggestion.SchemaName}.{suggestion.TableName}";
                            <li role="option"
                                class="px-3.5 py-2 text-sm text-gray-900 cursor-pointer hover:bg-brand-50 hover:text-brand-700 transition-colors"
                                @onmousedown="() => SelectSuggestion(displayName)"
                                @onmousedown:preventDefault>
                                @displayName
                            </li>
                        }
                    </ul>
                }
            </div>
            <button class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500/50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors shrink-0"
                    @onclick="GeneratePreviewAsync" disabled="@isLoading">
                @if (isLoading)
                {
                    <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                    <span>Generating...</span>
                }
                else
                {
                    <span>Generate Preview</span>
                }
            </button>
        </div>
    </div>

    @if (previewResult is not null && previewResult.Rows.Count > 0)
    {
        <div class="mt-6">
            <div class="flex items-center justify-between mb-3">
                <h3 class="text-lg font-semibold text-gray-900">
                    Preview for <span class="text-brand-600">@previewResult.TableName</span>
                    <span class="text-sm font-normal text-gray-500 ml-1">(@previewResult.Rows.Count row(s))</span>
                </h3>
            </div>

            @if (isStale)
            {
                <div class="mb-3 flex items-start gap-3 rounded-lg bg-amber-50 border border-amber-200 p-3" role="alert">
                    <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                    <p class="text-sm text-amber-700">Rules have been modified since this preview was generated. Click "Generate Preview" to refresh.</p>
                </div>
            }

            <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
                <!-- Desktop table -->
                <div class="overflow-x-auto hidden sm:block">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="bg-gray-50 text-left">
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Column</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Original</th>
                                <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Desensitized</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var (row, rowIndex) in previewResult.Rows.Select((r, i) => (r, i)))
                            {
                                <tr class="bg-gray-50">
                                    <td colspan="3" class="px-5 py-2 font-semibold text-xs text-gray-500 uppercase tracking-wider">Row @(rowIndex + 1)</td>
                                </tr>
                                @foreach (var key in row.OriginalValues.Keys)
                                {
                                    <tr class="hover:bg-gray-50 transition-colors">
                                        <td class="px-5 py-2.5 font-medium text-gray-900">@key</td>
                                        <td class="px-5 py-2.5 text-gray-600 font-mono text-xs">@FormatValue(row.OriginalValues[key])</td>
                                        <td class="px-5 py-2.5 text-brand-700 font-mono text-xs">@FormatValue(row.DesensitizedValues.GetValueOrDefault(key))</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
                <!-- Mobile cards -->
                <div class="sm:hidden divide-y divide-gray-100">
                    @foreach (var (row, rowIndex) in previewResult.Rows.Select((r, i) => (r, i)))
                    {
                        <div class="bg-gray-50 px-4 py-2">
                            <p class="font-semibold text-xs text-gray-500 uppercase tracking-wider">Row @(rowIndex + 1)</p>
                        </div>
                        @foreach (var key in row.OriginalValues.Keys)
                        {
                            <div class="px-4 py-3">
                                <p class="font-medium text-gray-900 text-sm">@key</p>
                                <div class="mt-1 grid grid-cols-2 gap-2 text-xs font-mono">
                                    <div>
                                        <span class="text-gray-400 text-[10px] uppercase block">Original</span>
                                        <span class="text-gray-600 break-all">@FormatValue(row.OriginalValues[key])</span>
                                    </div>
                                    <div>
                                        <span class="text-gray-400 text-[10px] uppercase block">Desensitized</span>
                                        <span class="text-brand-700 break-all">@FormatValue(row.DesensitizedValues.GetValueOrDefault(key))</span>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string tableName = string.Empty;
    private string? errorMessage;
    private string? infoMessage;
    private bool isLoading;
    private bool isStale;
    private PreviewResult? previewResult;
    private int rulesSnapshotHash;
    private List<TableInfo> tableSuggestions = new();
    private bool showSuggestions;
    private CancellationTokenSource? _searchCts;

    protected override void OnInitialized()
    {
        rulesSnapshotHash = ComputeRulesHash();
    }

    private async Task OnTableNameInputAsync()
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();
        var ct = _searchCts.Token;

        if (string.IsNullOrWhiteSpace(tableName))
        {
            tableSuggestions.Clear();
            showSuggestions = false;
            return;
        }

        try
        {
            var results = await SchemaService.SearchTablesAsync(tableName.Trim(), ct);
            if (!ct.IsCancellationRequested)
            {
                tableSuggestions = results;
                showSuggestions = tableSuggestions.Count > 0;
            }
        }
        catch (OperationCanceledException) { }
        catch
        {
            tableSuggestions.Clear();
            showSuggestions = false;
        }
    }

    private void SelectSuggestion(string displayName)
    {
        tableName = displayName;
        tableSuggestions.Clear();
        showSuggestions = false;
    }

    private async Task OnInputBlurAsync()
    {
        await Task.Delay(150);
        showSuggestions = false;
    }

    private async Task GeneratePreviewAsync()
    {
        errorMessage = null;
        infoMessage = null;
        previewResult = null;
        isStale = false;

        if (string.IsNullOrWhiteSpace(tableName))
        {
            errorMessage = "Please enter a table name.";
            return;
        }

        var tableRules = RuleConfigurationService.Rules
            .Where(r => string.Equals(r.TableName, tableName.Trim(), StringComparison.OrdinalIgnoreCase))
            .ToList();

        if (tableRules.Count == 0)
        {
            infoMessage = $"No desensitization rules are configured for table \"{tableName.Trim()}\".";
            return;
        }

        isLoading = true;
        try
        {
            previewResult = await DesensitizationEngine.PreviewAsync(tableName.Trim(), tableRules);
            rulesSnapshotHash = ComputeRulesHash();

            if (previewResult.Rows.Count == 0)
            {
                infoMessage = "Preview returned no rows. The table may be empty.";
                previewResult = null;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Preview failed: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private int ComputeRulesHash()
    {
        var hash = new HashCode();
        foreach (var rule in RuleConfigurationService.Rules)
        {
            hash.Add(rule);
        }
        return hash.ToHashCode();
    }

    private bool CheckStale()
    {
        var current = ComputeRulesHash();
        if (current != rulesSnapshotHash)
        {
            isStale = true;
            return true;
        }
        return false;
    }

    protected override void OnParametersSet()
    {
        if (previewResult is not null)
        {
            CheckStale();
        }
    }

    private static string FormatValue(object? value)
    {
        if (value is null || value == DBNull.Value)
            return "(null)";
        return value.ToString() ?? "(null)";
    }
}
