@page "/reports"
@rendermode InteractiveServer
@inject IReportSerializer ReportSerializer

<PageTitle>Execution Reports</PageTitle>

<div class="max-w-5xl">
    <h2 class="text-2xl font-bold text-gray-900">Execution Reports</h2>
    <p class="mt-1 text-sm text-gray-500">Import and export desensitization execution reports.</p>

    @if (successMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-emerald-50 border border-emerald-200 p-4" role="alert">
            <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-emerald-700">@successMessage</p>
        </div>
    }

    @if (errorMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
            <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-red-700">@errorMessage</p>
        </div>
    }

    <!-- Import Section -->
    <div class="mt-6 rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
        <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
            <h3 class="text-sm font-semibold text-gray-900">Import Report</h3>
        </div>
        <div class="p-5">
            <div class="flex flex-col sm:flex-row gap-4 items-end">
                <div class="flex-1">
                    <label for="importFilePath" class="block text-sm font-medium text-gray-700 mb-1.5">File Path</label>
                    <input type="text" id="importFilePath"
                           class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors"
                           @bind="importFilePath" placeholder="e.g. C:\reports\execution-report.json" />
                </div>
                <button class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500/50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors shrink-0"
                        @onclick="ImportReportAsync"
                        disabled="@(string.IsNullOrWhiteSpace(importFilePath))">
                    Import Report
                </button>
            </div>
        </div>
    </div>

    @if (report is not null)
    {
        <!-- Report Display -->
        <div class="mt-6 rounded-xl border border-sky-200 bg-white shadow-sm overflow-hidden">
            <div class="bg-sky-600 px-6 py-4">
                <h3 class="text-lg font-semibold text-white">Report Summary</h3>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Started</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.StartedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Completed</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.CompletedAt.ToString("yyyy-MM-dd HH:mm:ss")</p>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Total Elapsed</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.TotalElapsed.ToString(@"hh\:mm\:ss\.fff")</p>
                    </div>
                    <div class="rounded-lg bg-gray-50 p-3">
                        <p class="text-xs font-medium text-gray-500 uppercase tracking-wider">Rows Updated</p>
                        <p class="mt-1 text-sm font-semibold text-gray-900">@report.TotalRowsUpdated</p>
                    </div>
                </div>

                @if (report.TotalErrors > 0)
                {
                    <div class="mb-4 flex items-start gap-3 rounded-lg bg-amber-50 border border-amber-200 p-4">
                        <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                        <p class="text-sm text-amber-700">@report.TotalErrors table(s) encountered errors during execution.</p>
                    </div>
                }

                <div class="rounded-xl border border-gray-200 overflow-hidden">
                    <div class="overflow-x-auto">
                        <table class="w-full text-sm">
                            <thead>
                                <tr class="bg-gray-50 text-left">
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Table Name</th>
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Rows Updated</th>
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Elapsed</th>
                                    <th class="px-5 py-3 font-medium text-gray-500 text-xs uppercase tracking-wider">Status</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-100">
                                @foreach (var result in report.TableResults)
                                {
                                    <tr class="@(result.Error is not null ? "bg-red-50/50" : "hover:bg-gray-50") transition-colors">
                                        <td class="px-5 py-3 font-medium text-gray-900">@result.TableName</td>
                                        <td class="px-5 py-3 text-gray-700">@result.RowsUpdated</td>
                                        <td class="px-5 py-3 text-gray-500 font-mono text-xs">@result.Elapsed.ToString(@"hh\:mm\:ss\.fff")</td>
                                        <td class="px-5 py-3">
                                            @if (result.Error is not null)
                                            {
                                                <span class="text-red-600 text-xs">@result.Error</span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">Success</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Export Section -->
        <div class="mt-6 rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
            <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
                <h3 class="text-sm font-semibold text-gray-900">Export Report</h3>
            </div>
            <div class="p-5">
                <div class="flex flex-col sm:flex-row gap-4 items-end">
                    <div class="flex-1">
                        <label for="exportFilePath" class="block text-sm font-medium text-gray-700 mb-1.5">File Path</label>
                        <input type="text" id="exportFilePath"
                               class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors"
                               @bind="exportFilePath" placeholder="e.g. C:\reports\execution-report.json" />
                    </div>
                    <button class="inline-flex items-center gap-2 rounded-lg border border-brand-300 bg-white px-4 py-2.5 text-sm font-semibold text-brand-600 shadow-sm hover:bg-brand-50 focus:outline-none focus:ring-2 focus:ring-brand-500/50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors shrink-0"
                            @onclick="ExportReportAsync"
                            disabled="@(string.IsNullOrWhiteSpace(exportFilePath))">
                        Export Report
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private string importFilePath = string.Empty;
    private string exportFilePath = string.Empty;

    private string? successMessage;
    private string? errorMessage;

    private ExecutionReport? report;

    private void ClearMessages()
    {
        successMessage = null;
        errorMessage = null;
    }

    private async Task ImportReportAsync()
    {
        ClearMessages();
        try
        {
            report = await ReportSerializer.ImportFromFileAsync(importFilePath.Trim());
            successMessage = $"Report imported successfully. {report.TableResults.Count} table result(s) loaded.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to import report: {ex.Message}";
            report = null;
        }
    }

    private async Task ExportReportAsync()
    {
        ClearMessages();
        try
        {
            await ReportSerializer.ExportToFileAsync(report!, exportFilePath.Trim());
            successMessage = $"Report exported to '{exportFilePath.Trim()}'.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to export report: {ex.Message}";
        }
    }
}
