@page "/schema"
@inject ISchemaService SchemaService
@inject IRuleConfigurationService RuleConfigurationService

<PageTitle>Schema Browser</PageTitle>

<div class="max-w-5xl">
    <h2 class="text-xl sm:text-2xl font-bold text-gray-900">Schema Browser</h2>
    <p class="mt-1 text-sm text-gray-500">Explore your database tables and columns.</p>

    <div class="mt-4 sm:mt-6">
        <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
            <input type="text"
                   class="w-full rounded-lg border border-gray-300 pl-10 pr-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors"
                   placeholder="Search tables and columns..."
                   @bind="searchFilter" @bind:event="oninput" @bind:after="OnSearchChangedAsync" />
        </div>

        @if (errorMessage is not null)
        {
            <div class="mt-4 flex items-start gap-3 rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
                <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                <p class="text-sm text-red-700">@errorMessage</p>
            </div>
        }

        @if (isLoading)
        {
            <div class="mt-6 flex items-center gap-2 text-sm text-gray-500">
                <svg class="animate-spin h-4 w-4 text-brand-600" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                Loading schema...
            </div>
        }
        else if (tables.Count == 0)
        {
            <div class="mt-6 text-center py-12 rounded-xl border border-dashed border-gray-300 bg-white">
                <svg class="mx-auto w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7C5 4 4 5 4 7zm0 5h16"/></svg>
                <p class="mt-2 text-sm text-gray-500">No tables found. Make sure you are connected to a database.</p>
            </div>
        }
        else
        {
            <div class="mt-4 space-y-2">
                @foreach (var table in tables)
                {
                    var tableKey = $"{table.SchemaName}_{table.TableName}";
                    var isExpanded = expandedTables.Contains(tableKey);

                    <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
                        <button class="w-full flex items-center justify-between px-5 py-3.5 text-left hover:bg-gray-50 transition-colors"
                                @onclick="() => ToggleTableAsync(table, tableKey)">
                            <span class="font-medium text-sm text-gray-900">@table.SchemaName.@table.TableName</span>
                            <svg class="w-5 h-5 text-gray-400 transition-transform @(isExpanded ? "rotate-180" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>

                        @if (isExpanded)
                        {
                            <div class="border-t border-gray-100">
                                @if (columnsByTable.TryGetValue(tableKey, out var columns))
                                {
                                    <!-- Desktop table -->
                                    <div class="overflow-x-auto hidden sm:block">
                                        <table class="w-full text-sm">
                                            <thead>
                                                <tr class="bg-gray-50 text-left">
                                                    <th class="px-5 py-2.5 font-medium text-gray-500 text-xs uppercase tracking-wider">Column</th>
                                                    <th class="px-5 py-2.5 font-medium text-gray-500 text-xs uppercase tracking-wider">Data Type</th>
                                                    <th class="px-5 py-2.5 font-medium text-gray-500 text-xs uppercase tracking-wider">Nullable</th>
                                                    <th class="px-5 py-2.5 font-medium text-gray-500 text-xs uppercase tracking-wider">Status</th>
                                                </tr>
                                            </thead>
                                            <tbody class="divide-y divide-gray-100">
                                                @foreach (var col in FilterColumns(columns))
                                                {
                                                    var hasRule = HasAssignedRule(table.TableName, col.ColumnName);
                                                    var isSensitive = IsAutoDetectedSensitive(col.ColumnName);

                                                    <tr class="@(isSensitive && !hasRule ? "bg-amber-50/50" : "hover:bg-gray-50") transition-colors">
                                                        <td class="px-5 py-2.5 font-medium text-gray-900">@col.ColumnName</td>
                                                        <td class="px-5 py-2.5"><code class="text-xs bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded">@col.DataType@(col.MaxLength.HasValue ? $"({col.MaxLength})" : "")</code></td>
                                                        <td class="px-5 py-2.5">
                                                            @if (col.IsNullable)
                                                            {
                                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Nullable</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-800 text-white">Not Null</span>
                                                            }
                                                        </td>
                                                        <td class="px-5 py-2.5">
                                                            @if (hasRule)
                                                            {
                                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">
                                                                    &#x2714; Rule Assigned
                                                                </span>
                                                            }
                                                            else if (isSensitive)
                                                            {
                                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                                                    &#x26A0; Sensitive
                                                                </span>
                                                            }
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                    <!-- Mobile cards -->
                                    <div class="sm:hidden divide-y divide-gray-100">
                                        @foreach (var col in FilterColumns(columns))
                                        {
                                            var hasRule = HasAssignedRule(table.TableName, col.ColumnName);
                                            var isSensitive = IsAutoDetectedSensitive(col.ColumnName);

                                            <div class="px-4 py-3 @(isSensitive && !hasRule ? "bg-amber-50/50" : "")">
                                                <div class="flex items-center justify-between">
                                                    <span class="font-medium text-gray-900 text-sm">@col.ColumnName</span>
                                                    <code class="text-xs bg-gray-100 text-gray-600 px-1.5 py-0.5 rounded">@col.DataType@(col.MaxLength.HasValue ? $"({col.MaxLength})" : "")</code>
                                                </div>
                                                <div class="mt-1.5 flex flex-wrap items-center gap-1.5">
                                                    @if (col.IsNullable)
                                                    {
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Nullable</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-800 text-white">Not Null</span>
                                                    }
                                                    @if (hasRule)
                                                    {
                                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-emerald-100 text-emerald-700">&#x2714; Rule</span>
                                                    }
                                                    else if (isSensitive)
                                                    {
                                                        <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-medium bg-amber-100 text-amber-700">&#x26A0; Sensitive</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="px-5 py-4 flex items-center gap-2 text-sm text-gray-500">
                                        <svg class="animate-spin h-4 w-4 text-brand-600" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                                        Loading columns...
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private string searchFilter = string.Empty;
    private bool isLoading;
    private string? errorMessage;
    private List<TableInfo> tables = new();
    private HashSet<string> expandedTables = new();
    private Dictionary<string, List<ColumnInfo>> columnsByTable = new();

    private static readonly System.Text.RegularExpressions.Regex[] SensitivePatterns =
    [
        new(@"(?i)(first|last|full)?_?name", System.Text.RegularExpressions.RegexOptions.Compiled),
        new(@"(?i)e?mail", System.Text.RegularExpressions.RegexOptions.Compiled),
        new(@"(?i)phone|mobile|fax", System.Text.RegularExpressions.RegexOptions.Compiled),
        new(@"(?i)address|street|city|zip|postal", System.Text.RegularExpressions.RegexOptions.Compiled),
        new(@"(?i)ssn|social_security", System.Text.RegularExpressions.RegexOptions.Compiled),
        new(@"(?i)credit_card|card_number|ccn", System.Text.RegularExpressions.RegexOptions.Compiled),
        new(@"(?i)password|pwd|pass_hash", System.Text.RegularExpressions.RegexOptions.Compiled),
    ];

    protected override async Task OnInitializedAsync()
    {
        await LoadTablesAsync();
    }

    private async Task LoadTablesAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            tables = string.IsNullOrWhiteSpace(searchFilter)
                ? await SchemaService.GetTablesAsync()
                : await SchemaService.SearchTablesAsync(searchFilter);
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load schema: {ex.Message}";
            tables = new();
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OnSearchChangedAsync()
    {
        expandedTables.Clear();
        columnsByTable.Clear();
        await LoadTablesAsync();
    }

    private async Task ToggleTableAsync(TableInfo table, string tableKey)
    {
        if (expandedTables.Contains(tableKey))
        {
            expandedTables.Remove(tableKey);
            return;
        }

        expandedTables.Add(tableKey);

        if (!columnsByTable.ContainsKey(tableKey))
        {
            try
            {
                var fullName = $"{table.SchemaName}.{table.TableName}";
                var columns = await SchemaService.GetColumnsAsync(fullName);
                columnsByTable[tableKey] = columns;
            }
            catch (Exception ex)
            {
                errorMessage = $"Failed to load columns for {table.TableName}: {ex.Message}";
            }
        }
    }

    private List<ColumnInfo> FilterColumns(List<ColumnInfo> columns)
    {
        if (string.IsNullOrWhiteSpace(searchFilter))
            return columns;

        return columns
            .Where(c => c.ColumnName.Contains(searchFilter, StringComparison.OrdinalIgnoreCase))
            .ToList();
    }

    private bool HasAssignedRule(string tableName, string columnName)
    {
        return RuleConfigurationService.Rules.Any(r =>
            string.Equals(r.TableName, tableName, StringComparison.OrdinalIgnoreCase) &&
            string.Equals(r.ColumnName, columnName, StringComparison.OrdinalIgnoreCase));
    }

    private bool IsAutoDetectedSensitive(string columnName)
    {
        return SensitivePatterns.Any(p => p.IsMatch(columnName));
    }
}
