@page "/profiles"
@rendermode InteractiveServer
@inject IProfileManager ProfileManager
@inject IRuleConfigurationService RuleConfigurationService
@inject IConnectionManager ConnectionManager
@inject IJSRuntime JS

<PageTitle>Profile Management</PageTitle>

<div class="max-w-5xl">
    <h2 class="text-2xl font-bold text-gray-900">Profile Management</h2>
    <p class="mt-1 text-sm text-gray-500">Export and import rule configurations as JSON files.</p>

    @if (successMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-emerald-50 border border-emerald-200 p-4" role="alert">
            <svg class="w-5 h-5 text-emerald-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-emerald-700">@successMessage</p>
        </div>
    }

    @if (errorMessage is not null)
    {
        <div class="mt-4 flex items-start gap-3 rounded-lg bg-red-50 border border-red-200 p-4" role="alert">
            <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-red-700">@errorMessage</p>
        </div>
    }

    @if (warningMessages.Count > 0)
    {
        <div class="mt-4 rounded-lg bg-amber-50 border border-amber-200 p-4" role="alert">
            <div class="flex items-start gap-3">
                <svg class="w-5 h-5 text-amber-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
                <div>
                    <p class="text-sm font-medium text-amber-800">Unmatched Rules:</p>
                    <ul class="mt-1 text-sm text-amber-700 list-disc list-inside space-y-0.5">
                        @foreach (var warning in warningMessages)
                        {
                            <li>@warning</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    }

    <div class="mt-6 grid grid-cols-1 md:grid-cols-2 gap-5">
        <!-- Export Profile -->
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
            <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
                <h3 class="text-sm font-semibold text-gray-900">Export Profile</h3>
            </div>
            <div class="p-5 space-y-4">
                <p class="text-sm text-gray-500">Download current rules and migration history as a JSON file.</p>
                <div>
                    <label for="exportName" class="block text-sm font-medium text-gray-700 mb-1.5">Profile Name</label>
                    <input type="text" id="exportName"
                           class="w-full rounded-lg border border-gray-300 px-3.5 py-2.5 text-sm text-gray-900 placeholder-gray-400 shadow-sm focus:border-brand-500 focus:ring-2 focus:ring-brand-500/20 focus:outline-none transition-colors"
                           @bind="exportName" placeholder="Enter profile name" />
                </div>
                <div class="flex items-center justify-between">
                    <button class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-brand-700 focus:outline-none focus:ring-2 focus:ring-brand-500/50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                            @onclick="ExportProfileAsync"
                            disabled="@(string.IsNullOrWhiteSpace(exportName) || RuleConfigurationService.Rules.Count == 0 || ConnectionManager.Status != ConnectionStatus.Connected || isExporting)">
                        @if (isExporting)
                        {
                            <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                            <span>Exporting...</span>
                        }
                        else
                        {
                            <span>Export &amp; Download</span>
                        }
                    </button>
                    <span class="text-xs text-gray-500">@RuleConfigurationService.Rules.Count rule(s)</span>
                </div>
                @if (ConnectionManager.Status != ConnectionStatus.Connected)
                {
                    <p class="text-xs text-amber-600">A database connection is required for export.</p>
                }
            </div>
        </div>

        <!-- Import Profile -->
        <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-hidden">
            <div class="bg-gray-50 px-5 py-3 border-b border-gray-200">
                <h3 class="text-sm font-semibold text-gray-900">Import Profile</h3>
            </div>
            <div class="p-5 space-y-4">
                <p class="text-sm text-gray-500">Upload a JSON profile. Migration history must match the connected database.</p>
                <div>
                    <label for="importFile" class="block text-sm font-medium text-gray-700 mb-1.5">Select File</label>
                    <InputFile id="importFile" OnChange="OnFileSelected"
                               accept=".json"
                               class="block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-brand-50 file:text-brand-700 hover:file:bg-brand-100 transition-colors" />
                </div>
                <button class="inline-flex items-center gap-2 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 shadow-sm hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-brand-500/50 disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                        @onclick="ImportProfileAsync"
                        disabled="@(importFileBytes is null || ConnectionManager.Status != ConnectionStatus.Connected || isImporting)">
                    @if (isImporting)
                    {
                        <svg class="animate-spin h-4 w-4" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        <span>Importing...</span>
                    }
                    else
                    {
                        <span>Import Profile</span>
                    }
                </button>
                @if (ConnectionManager.Status != ConnectionStatus.Connected)
                {
                    <p class="text-xs text-amber-600">A database connection is required for import.</p>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private string exportName = string.Empty;
    private byte[]? importFileBytes;
    private bool isExporting;
    private bool isImporting;

    private string? successMessage;
    private string? errorMessage;
    private List<string> warningMessages = new();

    private void ClearMessages()
    {
        successMessage = null;
        errorMessage = null;
        warningMessages.Clear();
    }

    private async Task ExportProfileAsync()
    {
        ClearMessages();
        isExporting = true;

        try
        {
            var bytes = await ProfileManager.ExportProfileAsync(
                exportName.Trim(),
                RuleConfigurationService.Rules);

            var fileName = $"{exportName.Trim()}.json";
            await JS.InvokeVoidAsync("downloadFileFromBytes", fileName, bytes);

            successMessage = $"Profile '{exportName.Trim()}' exported with {RuleConfigurationService.Rules.Count} rule(s).";
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to export profile: {ex.Message}";
        }
        finally
        {
            isExporting = false;
        }
    }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        ClearMessages();
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            importFileBytes = ms.ToArray();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to read file: {ex.Message}";
            importFileBytes = null;
        }
    }

    private async Task ImportProfileAsync()
    {
        ClearMessages();
        if (importFileBytes is null) return;

        isImporting = true;

        try
        {
            var result = await ProfileManager.ImportProfileAsync(importFileBytes);

            if (!result.Success)
            {
                errorMessage = result.ErrorMessage ?? "Import failed due to migration history mismatch.";
                return;
            }

            if (result.LoadResult is not null)
            {
                foreach (var rule in RuleConfigurationService.Rules.ToList())
                {
                    RuleConfigurationService.RemoveRule(rule.TableName, rule.ColumnName);
                }

                foreach (var rule in result.LoadResult.MatchedRules)
                {
                    RuleConfigurationService.AddRule(rule);
                }

                successMessage = $"Profile imported. {result.LoadResult.MatchedRules.Count} rule(s) applied.";

                if (result.LoadResult.UnmatchedRules.Count > 0)
                {
                    foreach (var rule in result.LoadResult.UnmatchedRules)
                    {
                        warningMessages.Add($"{rule.TableName}.{rule.ColumnName} ({rule.Strategy}) — column not found in current schema.");
                    }
                }
            }
            else
            {
                successMessage = "Profile imported successfully.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to import profile: {ex.Message}";
        }
        finally
        {
            isImporting = false;
        }
    }
}
